<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>
      @page {
        size: A4;
        margin: 12mm 11mm;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        background: #eef3fb;
        color: #0f172a;
        font-family: "Segoe UI", Arial, sans-serif;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      body {
        padding: 10px;
        font-size: 11.5px;
        line-height: 1.35;
      }

      .sheet {
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        border: 1px solid #dbe6f4;
        border-radius: 18px;
        box-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
        overflow: hidden;
      }

      .accent-bar {
        height: 10px;
        background: linear-gradient(90deg, #123f7d 0%, #2f6fed 55%, #4cb5ff 100%);
      }

      .content {
        padding: 16px 18px 14px;
      }

      .header-grid {
        display: grid;
        grid-template-columns: 76px 1fr 76px;
        align-items: center;
        gap: 10px;
        padding-bottom: 12px;
        border-bottom: 1px solid #dbe6f4;
      }

      .brand-mark,
      .seal-mark,
      .signature-mark {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .brand-badge {
        width: 68px;
        height: 68px;
      }

      .seal-badge {
        width: 70px;
        height: 70px;
      }

      .school-copy {
        text-align: center;
        padding: 0 10px;
      }

      .school-name {
        margin: 0;
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 0.4px;
        color: #10264a;
        text-transform: uppercase;
      }

      .school-address {
        margin: 5px 0 0;
        font-size: 11.2px;
        color: #4b5563;
      }

      .school-contact {
        margin: 4px 0 0;
        font-size: 10.5px;
        color: #667085;
      }

      .title-wrap {
        text-align: center;
        padding: 12px 0 10px;
      }

      .title {
        display: inline-block;
        margin: 0;
        padding: 7px 18px;
        border-radius: 999px;
        background: linear-gradient(90deg, #123f7d, #2f6fed);
        color: #ffffff;
        font-size: 16px;
        font-weight: 800;
        letter-spacing: 1px;
      }

      .meta-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin-top: 4px;
      }

      .meta-card {
        background: #f7fbff;
        border: 1px solid #d8e6f6;
        border-radius: 12px;
        padding: 8px 10px;
        min-height: 56px;
      }

      .meta-label {
        font-size: 10.5px;
        font-weight: 700;
        color: #5f6f84;
        text-transform: uppercase;
        letter-spacing: 0.6px;
      }

      .meta-value {
        margin-top: 5px;
        font-size: 11.5px;
        font-weight: 700;
        color: #10264a;
        word-break: break-word;
      }

      .section {
        margin-top: 12px;
        padding: 12px 14px;
        border: 1px solid #dbe6f4;
        border-radius: 14px;
        background: #ffffff;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .section-title {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0 0 10px;
        font-size: 12px;
        font-weight: 800;
        color: #123f7d;
        text-transform: uppercase;
        letter-spacing: 0.8px;
      }

      .section-title::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: #2f6fed;
      }

      .student-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 14px;
      }

      .detail-list {
        display: grid;
        gap: 6px;
      }

      .detail-item {
        display: flex;
        gap: 10px;
        align-items: flex-start;
      }

      .detail-label {
        min-width: 108px;
        font-size: 10px;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .detail-value {
        flex: 1;
        font-size: 11.5px;
        font-weight: 700;
        color: #10264a;
        border-bottom: 1px dotted #d7e2f0;
        padding-bottom: 2px;
      }

      .table-wrap {
        margin-top: 12px;
        border: 1px solid #dbe6f4;
        border-radius: 14px;
        overflow: hidden;
        background: #ffffff;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        page-break-inside: auto;
      }

      thead {
        display: table-header-group;
      }

      thead th {
        background: linear-gradient(90deg, #123f7d, #2f6fed);
        color: #ffffff;
        padding: 10px 8px;
        text-align: left;
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.6px;
        text-transform: uppercase;
      }

      tbody td {
        padding: 8px 8px;
        border-top: 1px solid #e6eef8;
        font-size: 10.8px;
        color: #1f2937;
        vertical-align: top;
      }

      tbody {
        counter-reset: receipt-row;
      }

      tbody tr {
        counter-increment: receipt-row;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      td.srno::before {
        content: counter(receipt-row);
        font-weight: 800;
        color: #10264a;
      }

      tbody tr:nth-child(even) td {
        background: #f9fbff;
      }

      .center {
        text-align: center;
      }

      .right {
        text-align: right;
      }

      .fee-name {
        font-weight: 700;
        color: #10264a;
      }

      .footer {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        align-items: end;
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #dbe6f4;
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .footer-box {
        min-height: 78px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .signature-block {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
      }

      .signature-line {
        width: 170px;
        border-top: 1px solid #10264a;
        margin-top: 30px;
      }

      .signature-label {
        font-size: 12px;
        font-weight: 800;
        color: #10264a;
      }

      .subtle {
        font-size: 11px;
        color: #64748b;
      }

      .seal-text {
        font-size: 10px;
        fill: #123f7d;
        font-weight: 700;
        letter-spacing: 1px;
      }

      .seal-title {
        font-size: 11px;
        font-weight: 800;
        color: #123f7d;
        margin-top: 4px;
        text-transform: uppercase;
      }

      .logo-text {
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.7px;
        fill: #10264a;
      }

      .logo-sub {
        font-size: 7px;
        fill: #4b5563;
        font-weight: 700;
        letter-spacing: 0.6px;
      }
    </style>
  </head>

  <body>
    <div class="sheet">
      <div class="accent-bar"></div>

      <div class="content">
        <div class="header-grid">
          <div class="brand-mark">
            <svg class="brand-badge" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <linearGradient id="logoBg" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#123f7d" />
                  <stop offset="100%" stop-color="#4cb5ff" />
                </linearGradient>
              </defs>
              <circle cx="60" cy="60" r="55" fill="url(#logoBg)" />
              <circle cx="60" cy="60" r="43" fill="none" stroke="rgba(255,255,255,0.92)" stroke-width="3" />
              <path d="M35 50h50v8H35z" fill="#ffffff" opacity="0.95" />
              <path d="M39 60h42v22H39z" fill="#ffffff" opacity="0.9" />
              <path d="M48 50v32" stroke="#123f7d" stroke-width="4" opacity="0.7" />
              <path d="M72 50v32" stroke="#123f7d" stroke-width="4" opacity="0.7" />
              <text x="60" y="92" text-anchor="middle" class="logo-text">SCHOOL</text>
              <text x="60" y="103" text-anchor="middle" class="logo-sub">RECEIPT</text>
            </svg>
          </div>

          <div class="school-copy">
            <p class="school-name">{{schoolName}}</p>
            <p class="school-address">{{schoolAddress}}</p>
            <p class="school-contact">
              {{#if schoolPhone}}Phone: {{schoolPhone}}{{else}}Phone: N/A{{/if}}
              &nbsp;|&nbsp;
              {{#if schoolEmail}}Email: {{schoolEmail}}{{else}}Email: N/A{{/if}}
            </p>
          </div>

          <div class="seal-mark">
            <svg class="seal-badge" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="60" cy="60" r="54" fill="#f8fbff" stroke="#123f7d" stroke-width="4" />
              <circle cx="60" cy="60" r="44" fill="none" stroke="#4cb5ff" stroke-width="2.5" stroke-dasharray="5 5" />
              <circle cx="60" cy="60" r="25" fill="none" stroke="#123f7d" stroke-width="2.5" />
              <path d="M46 67l9-10 8 7 12-16" fill="none" stroke="#123f7d" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
              <text x="60" y="26" text-anchor="middle" class="seal-text">OFFICIAL</text>
              <text x="60" y="102" text-anchor="middle" class="seal-text">SEAL</text>
            </svg>
          </div>
        </div>

        <div class="title-wrap">
          <h1 class="title">FEE RECEIPT</h1>
        </div>

        <div class="meta-grid">
          <div class="meta-card">
            <div class="meta-label">Receipt Number</div>
            <div class="meta-value">{{receiptNumber}}</div>
          </div>
          <div class="meta-card">
            <div class="meta-label">Date</div>
            <div class="meta-value">{{date}}</div>
          </div>
          <div class="meta-card">
            <div class="meta-label">Payment Method</div>
            <div class="meta-value">{{#if paymentMethod}}{{paymentMethod}}{{else}}N/A{{/if}}</div>
          </div>
          <div class="meta-card">
            <div class="meta-label">Session</div>
            <div class="meta-value">{{#if session}}{{session}}{{else}}N/A{{/if}}</div>
          </div>
        </div>

        <div class="section">
          <h2 class="section-title">Student Details</h2>
          <div class="student-grid">
            <div class="detail-list">
              <div class="detail-item">
                <div class="detail-label">Student Name</div>
                <div class="detail-value">{{studentName}}</div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Father Name</div>
                <div class="detail-value">{{fatherName}}</div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Roll Number</div>
                <div class="detail-value">{{#if rollNumber}}{{rollNumber}}{{else}}N/A{{/if}}</div>
              </div>
            </div>

            <div class="detail-list">
              <div class="detail-item">
                <div class="detail-label">Class</div>
                <div class="detail-value">{{className}}</div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Section</div>
                <div class="detail-value">{{sectionName}}</div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Admission No</div>
                <div class="detail-value">{{#if admissionNo}}{{admissionNo}}{{else}}N/A{{/if}}</div>
              </div>
            </div>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th style="width: 54px;">Sr No</th>
                <th>Fee Type</th>
                <th style="width: 100px;">Month</th>
                <th class="right" style="width: 112px;">Total</th>
                <th class="right" style="width: 112px;">Paid</th>
                <th class="right" style="width: 112px;">Pending</th>
              </tr>
            </thead>
            <tbody>
              {{#each fees}}
                <tr>
                  <td class="center srno"></td>
                  <td class="fee-name">{{this.feeType}}</td>
                  <td>{{this.month}}</td>
                  <td class="right">₹ {{this.totalAmount}}</td>
                  <td class="right">₹ {{this.paidAmount}}</td>
                  <td class="right">₹ {{this.remainingAmount}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <div class="footer">
          <div class="footer-box">
            <div>
              <svg class="seal-badge" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="60" cy="60" r="54" fill="#f8fbff" stroke="#123f7d" stroke-width="4" />
                <circle cx="60" cy="60" r="44" fill="none" stroke="#4cb5ff" stroke-width="2.5" stroke-dasharray="5 5" />
                <circle cx="60" cy="60" r="25" fill="none" stroke="#123f7d" stroke-width="2.5" />
                <path d="M46 67l9-10 8 7 12-16" fill="none" stroke="#123f7d" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                <text x="60" y="26" text-anchor="middle" class="seal-text">OFFICIAL</text>
                <text x="60" y="102" text-anchor="middle" class="seal-text">SEAL</text>
              </svg>
              <div class="seal-title">School Seal</div>
            </div>
          </div>

          <div class="footer-box">
            <div class="signature-block">
              <svg width="190" height="80" viewBox="0 0 190 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M16 52C29 50 35 35 45 38C54 41 54 57 65 56C76 55 77 31 89 32C101 33 101 52 110 53C121 54 125 39 135 37C146 35 151 44 161 44C171 44 175 36 181 35" fill="none" stroke="#123f7d" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M18 60H172" stroke="#1f2937" stroke-width="1.3" stroke-linecap="round" />
              </svg>
              <div class="signature-label">Authorized Signatory</div>
              <div class="subtle">School Admin</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
